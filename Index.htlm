    <button class="filter-btn" onclick="filterVocab('food',this)">🍽️ Nourriture</button>
    <button class="filter-btn" onclick="filterVocab('emotions',this)">😊 Émotions</button>
    <button class="filter-btn" onclick="filterVocab('verbs',this)">🔧 Verbes</button>
