<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MadameEnglish 🇬🇧</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --beige:#f5efe6;--beige2:#ede4d6;--beige3:#ddd0bc;
  --sage:#7a9e7e;--sage-dark:#4d7a52;--sage-light:#b5cdb7;--sage-pale:#e8f0e9;
  --brown:#8b6f5e;--brown-light:#c4a882;
  --text:#2c2416;--text-light:#7a6a5a;--white:#fffdf9;
  --gold:#c9a84c;--red:#c0392b;--shadow:rgba(44,36,22,0.08);
  --music:#6b4fa0;--music-light:#e8e0f5;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--beige);color:var(--text);min-height:100vh;display:flex;}

.sidebar{position:fixed;left:0;top:0;width:270px;height:100vh;background:var(--white);border-right:1px solid var(--beige3);overflow-y:auto;z-index:100;display:flex;flex-direction:column;}
.sidebar-header{padding:1.5rem 1.5rem 1rem;border-bottom:1px solid var(--beige3);background:linear-gradient(160deg,var(--sage-pale),var(--white));}
.logo{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:700;color:var(--sage-dark);}
.logo span{color:var(--brown);}
.logo-sub{font-size:0.68rem;color:var(--text-light);text-transform:uppercase;letter-spacing:0.15em;margin-top:0.1rem;}

.level-gauge{padding:1rem 1.5rem;border-bottom:1px solid var(--beige3);background:var(--beige);}
.level-label{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;}
.level-title{font-size:0.72rem;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:0.1em;}
.level-badge{background:var(--sage);color:var(--white);font-size:0.63rem;padding:2px 8px;border-radius:20px;font-weight:600;}
.gauge-track{background:var(--beige3);border-radius:50px;height:6px;overflow:hidden;}
.gauge-fill{background:linear-gradient(90deg,var(--sage),var(--sage-dark));height:100%;border-radius:50px;width:72%;transition:width 1s ease;}
.gauge-stats{display:flex;justify-content:space-between;margin-top:0.4rem;font-size:0.68rem;color:var(--text-light);}
.streak-box{display:flex;align-items:center;gap:0.4rem;margin-top:0.7rem;background:var(--white);border-radius:8px;padding:0.45rem 0.8rem;font-size:0.78rem;}
.streak-num{font-weight:700;color:var(--brown);}

.nav-body{padding:0.8rem;flex:1;overflow-y:auto;}
.nav-section{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--sage);font-weight:600;padding:0.7rem 0.6rem 0.2rem;}
.nav-item{display:flex;align-items:center;gap:0.5rem;padding:0.48rem 0.7rem;border-radius:9px;color:var(--text);font-size:0.82rem;cursor:pointer;transition:all 0.2s;margin-bottom:1px;user-select:none;}
.nav-item:hover{background:var(--sage-pale);color:var(--sage-dark);}
.nav-item.active{background:var(--sage);color:var(--white);font-weight:500;}
.nav-done{margin-left:auto;font-size:0.6rem;background:var(--sage-light);color:var(--sage-dark);padding:1px 5px;border-radius:8px;}
.nav-item.active .nav-done{background:rgba(255,255,255,0.3);color:var(--white);}
.nav-new{margin-left:auto;font-size:0.6rem;background:#faf0d0;color:var(--gold);padding:1px 5px;border-radius:8px;font-weight:600;}
.nav-music{margin-left:auto;font-size:0.6rem;background:var(--music-light);color:var(--music);padding:1px 5px;border-radius:8px;font-weight:600;}
.nav-100{margin-left:auto;font-size:0.6rem;background:#faeae8;color:var(--red);padding:1px 5px;border-radius:8px;font-weight:600;}

.main{margin-left:270px;padding:2rem 2.5rem;flex:1;min-height:100vh;}
.section{display:none;animation:fadeIn 0.3s ease;}
.section.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.hero{background:linear-gradient(135deg,var(--sage-dark),var(--sage));border-radius:20px;padding:2rem 2.5rem;color:var(--white);margin-bottom:1.8rem;position:relative;overflow:hidden;}
.hero::before{content:'🇬🇧';position:absolute;right:1.5rem;top:50%;transform:translateY(-50%);font-size:7rem;opacity:0.12;}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:700;line-height:1.1;margin-bottom:0.4rem;}
.hero-sub{font-size:0.92rem;opacity:0.85;margin-bottom:1.2rem;}
.hero-stats{display:flex;gap:1.5rem;flex-wrap:wrap;}
.hero-stat-num{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;}
.hero-stat-label{font-size:0.7rem;opacity:0.75;}

.page-title{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;color:var(--sage-dark);margin-bottom:0.2rem;}
.page-sub{color:var(--text-light);font-size:0.87rem;margin-bottom:1.5rem;}

.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.9rem;margin-bottom:1.8rem;}
.card{background:var(--white);border-radius:14px;padding:1.2rem;cursor:pointer;transition:all 0.25s;border:1.5px solid var(--beige3);}
.card:hover{transform:translateY(-3px);border-color:var(--sage-light);box-shadow:0 10px 25px var(--shadow);}
.card-icon{font-size:1.6rem;margin-bottom:0.6rem;}
.card-title{font-weight:600;font-size:0.9rem;margin-bottom:0.15rem;}
.card-sub{font-size:0.72rem;color:var(--text-light);}

.lesson-card{background:var(--white);border-radius:14px;padding:1.6rem;margin-bottom:1rem;border:1.5px solid var(--beige3);box-shadow:0 2px 8px var(--shadow);}
.lesson-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:700;color:var(--sage-dark);margin-bottom:0.9rem;}

.rule-table{width:100%;border-collapse:collapse;margin:0.7rem 0;font-size:0.85rem;}
.rule-table th{background:var(--sage-pale);color:var(--sage-dark);padding:0.55rem 0.9rem;text-align:left;font-weight:600;font-size:0.78rem;}
.rule-table td{padding:0.55rem 0.9rem;border-bottom:1px solid var(--beige3);}
.rule-table tr:last-child td{border-bottom:none;}
.rule-table tr:hover td{background:var(--beige);}

.tag{display:inline-block;padding:2px 9px;border-radius:20px;font-size:0.75rem;font-weight:600;}
.tag-sage{background:var(--sage-pale);color:var(--sage-dark);border:1px solid var(--sage-light);}
.tag-brown{background:#f5ede6;color:var(--brown);border:1px solid var(--brown-light);}
.tag-red{background:#faeae8;color:var(--red);border:1px solid #e8b0a8;}
.tag-gold{background:#faf3e0;color:var(--gold);border:1px solid #e8d48a;}
.tag-music{background:var(--music-light);color:var(--music);border:1px solid #c4b0e0;}

.tip-box{background:var(--sage-pale);border-left:3px solid var(--sage);border-radius:0 9px 9px 0;padding:0.8rem 1rem;margin:0.9rem 0;font-size:0.85rem;line-height:1.6;}
.warn-box{background:#fdf3f0;border-left:3px solid #e8907a;border-radius:0 9px 9px 0;padding:0.8rem 1rem;margin:0.9rem 0;font-size:0.85rem;line-height:1.6;}
.info-box{background:#f5f0e6;border-left:3px solid var(--gold);border-radius:0 9px 9px 0;padding:0.8rem 1rem;margin:0.9rem 0;font-size:0.85rem;line-height:1.6;}
.music-box{background:var(--music-light);border-left:3px solid var(--music);border-radius:0 9px 9px 0;padding:0.8rem 1rem;margin:0.9rem 0;font-size:0.85rem;line-height:1.6;}

.example{background:var(--beige);border-radius:9px;padding:0.75rem 0.9rem;margin:0.35rem 0;font-size:0.85rem;}
.example .en{color:var(--sage-dark);font-weight:500;}
.example .fr{color:var(--text-light);font-size:0.8rem;margin-top:2px;}

.three-types{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.8rem;margin:0.8rem 0;}
.type-card{border-radius:12px;padding:1rem;text-align:center;}
.type-card.affirm{background:#e8f5ec;border:1.5px solid #7ec89a;}
.type-card.neg{background:#faeae8;border:1.5px solid #e8907a;}
.type-card.interro{background:#faf3e0;border:1.5px solid #e8d48a;}
.type-card .type-label{font-weight:700;font-size:0.85rem;margin-bottom:0.4rem;}
.type-card.affirm .type-label{color:#2d7a4f;}
.type-card.neg .type-label{color:var(--red);}
.type-card.interro .type-label{color:var(--gold);}
.type-card .type-formula{font-size:0.75rem;color:var(--text-light);margin-bottom:0.4rem;}
.type-card .type-example{font-size:0.82rem;font-weight:500;}

.film-box{background:linear-gradient(135deg,var(--sage-pale),var(--beige));border:1.5px solid var(--sage-light);border-radius:12px;padding:1rem;margin:0.5rem 0;display:flex;align-items:center;gap:0.9rem;}
.film-emoji{font-size:2rem;}
.film-title{font-weight:600;color:var(--sage-dark);font-size:0.9rem;margin-bottom:0.2rem;}
.film-rule{font-size:0.82rem;color:var(--text-light);}

.vocab-filters{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;}
.filter-btn{background:var(--white);border:1.5px solid var(--beige3);border-radius:50px;padding:0.38rem 0.9rem;font-family:'DM Sans',sans-serif;font-size:0.78rem;cursor:pointer;color:var(--text-light);transition:all 0.2s;}
.filter-btn:hover,.filter-btn.active{background:var(--sage);border-color:var(--sage);color:var(--white);}
.vocab-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:0.7rem;}
.vocab-card{background:var(--white);border-radius:11px;padding:0.9rem;border:1.5px solid var(--beige3);cursor:pointer;transition:all 0.25s;text-align:center;}
.vocab-card:hover{transform:translateY(-2px);border-color:var(--sage-light);}
.vocab-en{font-size:0.95rem;font-weight:600;color:var(--sage-dark);margin-bottom:0.25rem;}
.vocab-fr{font-size:0.78rem;color:var(--text-light);}
.vocab-cat{font-size:0.62rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--brown-light);margin-bottom:0.35rem;}

/* MEGA QUIZ STYLES */
.quiz-progress-bar{background:var(--beige3);border-radius:50px;height:8px;margin-bottom:1.5rem;overflow:hidden;}
.quiz-progress-fill{background:linear-gradient(90deg,var(--sage),var(--sage-dark));height:100%;border-radius:50px;transition:width 0.4s ease;}
.quiz-progress-label{display:flex;justify-content:space-between;font-size:0.78rem;color:var(--text-light);margin-bottom:0.4rem;}

.quiz-category-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:0.72rem;font-weight:600;margin-bottom:0.7rem;}
.cat-grammar{background:var(--sage-pale);color:var(--sage-dark);}
.cat-vocab{background:#faf3e0;color:var(--gold);}
.cat-conjugaison{background:#faeae8;color:var(--red);}
.cat-phrases{background:var(--music-light);color:var(--music);}
.cat-pronoms{background:#f5ede6;color:var(--brown);}

.quiz-question-card{background:var(--white);border-radius:16px;padding:1.5rem;border:1.5px solid var(--beige3);box-shadow:0 2px 8px var(--shadow);margin-bottom:1rem;}
.quiz-q-num{font-size:0.72rem;color:var(--text-light);margin-bottom:0.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;}
.quiz-q-text{font-size:0.95rem;font-weight:500;margin-bottom:1rem;color:var(--text);line-height:1.5;}
.quiz-opts{display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;}
.quiz-opt{background:var(--beige);border:1.5px solid var(--beige3);border-radius:9px;padding:0.62rem 0.9rem;color:var(--text);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:0.85rem;transition:all 0.2s;text-align:left;}
.quiz-opt:hover:not(:disabled){background:var(--sage-pale);border-color:var(--sage-light);}
.quiz-opt.correct{background:#e8f5ec;border-color:#7ec89a;color:#2d7a4f;}
.quiz-opt.wrong{background:#faeae8;border-color:#e8907a;color:var(--red);}
.quiz-opt:disabled{cursor:default;}
.quiz-feedback-card{margin-top:0.7rem;font-size:0.82rem;padding:0.6rem 0.9rem;border-radius:8px;display:none;line-height:1.5;}
.quiz-feedback-card.show{display:block;}
.quiz-feedback-card.correct{background:#e8f5ec;color:#2d7a4f;}
.quiz-feedback-card.wrong{background:#faeae8;color:var(--red);}

.quiz-nav{display:flex;gap:0.8rem;align-items:center;margin-top:1.2rem;flex-wrap:wrap;}

/* SCORE SCREEN */
.score-screen{display:none;text-align:center;padding:3rem 2rem;}
.score-screen.show{display:block;}
.score-big{font-family:'Cormorant Garamond',serif;font-size:6rem;font-weight:700;color:var(--sage-dark);line-height:1;}
.score-label{font-size:1rem;color:var(--text-light);margin-top:0.5rem;}
.score-mention{margin:1rem auto;font-size:1.1rem;font-weight:600;padding:0.6rem 1.5rem;border-radius:50px;display:inline-block;}
.score-details{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:0.8rem;margin:2rem 0;text-align:left;}
.score-detail-card{background:var(--white);border-radius:12px;padding:1rem;border:1.5px solid var(--beige3);}
.score-detail-cat{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-light);margin-bottom:0.3rem;}
.score-detail-num{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--sage-dark);}
.score-detail-label{font-size:0.75rem;color:var(--text-light);}

/* EXERCISE */
.ex-sentence{font-size:0.88rem;line-height:2.2;}
.exercise-input{background:var(--beige);border:1.5px solid var(--beige3);border-radius:7px;padding:0.28rem 0.7rem;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.85rem;width:130px;outline:none;transition:border 0.2s;}
.exercise-input:focus{border-color:var(--sage);}
.exercise-input.correct{border-color:#7ec89a;background:#e8f5ec;}
.exercise-input.wrong{border-color:#e8907a;background:#faeae8;}

.btn{background:var(--sage-dark);border:none;border-radius:9px;padding:0.7rem 1.8rem;color:var(--white);font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.88rem;cursor:pointer;transition:all 0.2s;margin-top:0.9rem;}
.btn:hover{background:var(--sage);transform:translateY(-1px);box-shadow:0 5px 14px rgba(77,122,82,0.3);}
.btn-outline{background:transparent;border:1.5px solid var(--beige3);border-radius:9px;padding:0.7rem 1.8rem;color:var(--text-light);font-family:'DM Sans',sans-serif;font-weight:500;font-size:0.88rem;cursor:pointer;transition:all 0.2s;margin-top:0.9rem;margin-left:0.4rem;}
.btn-outline:hover{border-color:var(--sage);color:var(--sage-dark);}

.score-display{text-align:center;padding:1.8rem;background:linear-gradient(135deg,var(--sage-pale),var(--beige));border-radius:14px;margin-top:1.2rem;border:1.5px solid var(--sage-light);display:none;}
.score-display.show{display:block;}
.score-number{font-family:'Cormorant Garamond',serif;font-size:3.5rem;color:var(--sage-dark);font-weight:700;}

.flashcard-container{perspective:1000px;max-width:380px;margin:0 auto;}
.flashcard{width:100%;height:200px;position:relative;transform-style:preserve-3d;transition:transform 0.6s;cursor:pointer;}
.flashcard.flipped{transform:rotateY(180deg);}
.flashcard-front,.flashcard-back{position:absolute;width:100%;height:100%;backface-visibility:hidden;border-radius:18px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem;text-align:center;}
.flashcard-front{background:var(--white);border:1.5px solid var(--beige3);box-shadow:0 8px 20px var(--shadow);}
.flashcard-back{background:var(--sage);color:var(--white);transform:rotateY(180deg);}
.flashcard-word{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--sage-dark);}
.flashcard-back .flashcard-word{color:var(--white);}
.flashcard-hint{font-size:0.75rem;color:var(--text-light);margin-top:0.4rem;}
.flashcard-back .flashcard-hint{color:rgba(255,255,255,0.75);}
.flashcard-nav{display:flex;justify-content:center;gap:0.9rem;margin-top:1.3rem;align-items:center;}

.music-card{background:var(--white);border-radius:14px;margin-bottom:1rem;border:1.5px solid var(--beige3);overflow:hidden;}
.music-header{background:linear-gradient(135deg,var(--music),#8b6fc0);padding:1.2rem 1.5rem;color:var(--white);display:flex;align-items:center;gap:1rem;}
.music-emoji{font-size:2rem;}
.music-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;}
.music-artist{font-size:0.82rem;opacity:0.85;}
.music-body{padding:1.3rem 1.5rem;}
.lyric-line{background:var(--beige);border-radius:10px;padding:0.9rem 1rem;margin-bottom:0.6rem;border-left:3px solid var(--sage-light);}
.lyric-line.highlight{border-left-color:var(--music);background:var(--music-light);}
.lyric-en{font-size:0.9rem;font-weight:600;color:var(--sage-dark);margin-bottom:0.2rem;}
.lyric-fr{font-size:0.82rem;color:var(--text-light);margin-bottom:0.3rem;}
.lyric-explain{font-size:0.78rem;color:var(--music);background:var(--music-light);border-radius:6px;padding:0.3rem 0.6rem;display:inline-block;margin-top:0.2rem;}
.lyric-grammar{font-size:0.75rem;color:var(--sage-dark);background:var(--sage-pale);border-radius:6px;padding:0.25rem 0.6rem;display:inline-block;margin-top:0.2rem;margin-left:0.3rem;}

.badges-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:0.9rem;}
.badge-card{background:var(--white);border-radius:12px;padding:1.1rem;text-align:center;border:1.5px solid var(--beige3);}
.badge-card.earned{border-color:var(--gold);background:#faf3e0;}
.badge-card.locked{opacity:0.45;}
.badge-emoji{font-size:1.8rem;margin-bottom:0.4rem;}
.badge-name{font-size:0.78rem;font-weight:600;}
.badge-desc{font-size:0.67rem;color:var(--text-light);margin-top:0.15rem;}

.chrono-display{background:var(--white);border:1.5px solid var(--beige3);border-radius:10px;padding:0.7rem 1.2rem;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1.2rem;font-size:0.85rem;}
.chrono-time{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:var(--sage-dark);}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:var(--beige);}::-webkit-scrollbar-thumb{background:var(--beige3);border-radius:3px;}
h3{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--sage-dark);margin:1rem 0 0.5rem;font-weight:700;}
p{line-height:1.7;color:var(--text);font-size:0.88rem;}
@media(max-width:900px){.sidebar{width:100%;height:auto;position:relative;}.main{margin-left:0;padding:1rem;}.two-col,.three-types,.quiz-opts{grid-template-columns:1fr;}}
</style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-header">
    <div class="logo">Madame<span>English</span> 🇬🇧</div>
    <div class="logo-sub">Ton espace d'apprentissage</div>
  </div>
  <div class="level-gauge">
    <div class="level-label"><span class="level-title">Niveau global</span><span class="level-badge">A2 → B1</span></div>
    <div class="gauge-track"><div class="gauge-fill"></div></div>
    <div class="gauge-stats"><span>72% maîtrisé</span><span>8/14 chapitres</span></div>
    <div class="streak-box">🔥 <span class="streak-num">12</span> <span style="font-size:0.72rem;color:var(--text-light)">jours consécutifs</span></div>
  </div>
  <div class="nav-body">
    <div class="nav-section">🏠 Accueil</div>
    <div class="nav-item active" onclick="show('home',this)">🏠 Tableau de bord</div>
    <div class="nav-item" onclick="show('badges',this)">🏆 Mes badges</div>
    <div class="nav-item" onclick="show('flashcards',this)">🃏 Flashcards</div>
    <div class="nav-section">🎯 L'essentiel</div>
    <div class="nav-item" onclick="show('types',this)">📝 Phrases A/N/I <span class="nav-done">✓</span></div>
    <div class="nav-section">📖 Grammaire</div>
    <div class="nav-item" onclick="show('a-an',this)">📌 A / AN <span class="nav-done">✓</span></div>
    <div class="nav-item" onclick="show('has-have',this)">📌 HAS / HAVE <span class="nav-done">✓</span></div>
    <div class="nav-item" onclick="show('am-is-are',this)">📌 AM / IS / ARE <span class="nav-done">✓</span></div>
    <div class="nav-item" onclick="show('ing',this)">🔄 -ING <span class="nav-done">✓</span></div>
    <div class="nav-item" onclick="show('do-does',this)">❓ DO / DOES <span class="nav-done">✓</span></div>
    <div class="nav-item" onclick="show('dont-doesnt',this)">❌ DON'T / DOESN'T <span class="nav-done">✓</span></div>
