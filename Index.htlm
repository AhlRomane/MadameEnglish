<!-- ==================== MEGA QUIZ ==================== -->
<div id="mega-quiz" class="section">
  <div id="mq-intro">
    <div class="page-title">🏆 Méga Quiz — 100 Questions</div>
    <div class="page-sub">Le grand défi sur TOUT ce que tu as appris !</div>
    <div class="lesson-card">
      <div class="lesson-title">📋 Comment ça marche ?</div>
      <p style="margin-bottom:1rem">100 questions couvrant toute la grammaire, le vocabulaire, la conjugaison et les phrases du site. Réponds à ton rythme, la correction s'affiche après chaque réponse.</p>
      <table class="rule-table">
        <tr><th>Catégorie</th><th>Questions</th></tr>
        <tr><td>📌 A/AN</td><td>10 questions</td></tr>
        <tr><td>📌 HAS/HAVE</td><td>10 questions</td></tr>
        <tr><td>📌 AM/IS/ARE + ING</td><td>10 questions</td></tr>
        <tr><td>❓ DO/DOES/DON'T/DOESN'T</td><td>10 questions</td></tr>
        <tr><td>⏮️ WAS/WERE/DID/DIDN'T</td><td>15 questions</td></tr>
        <tr><td>🔮 Futur & Present Perfect</td><td>10 questions</td></tr>
        <tr><td>👤 Pronoms & Adjectifs</td><td>10 questions</td></tr>
        <tr><td>📍 Prépositions</td><td>5 questions</td></tr>
        <tr><td>📚 Vocabulaire</td><td>10 questions</td></tr>
        <tr><td>🔤 Pluriels irréguliers</td><td>5 questions</td></tr>
        <tr><td>📝 Phrases A/N/I</td><td>5 questions</td></tr>
      </table>
      <button class="btn" onclick="startMegaQuiz()" style="margin-top:1.2rem;font-size:1rem;padding:0.9rem 2.5rem">🚀 Commencer le Méga Quiz !</button>
    </div>
  </div>

  <div id="mq-content" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.5rem">
      <div class="page-title" style="margin-bottom:0;font-size:1.6rem">🏆 Méga Quiz</div>
      <div style="font-size:0.88rem;color:var(--text-light)">Score en cours : <strong id="mq-live-score">0</strong>/100</div>
    </div>
    <div class="quiz-progress-label"><span id="mq-progress-text">Question 1/100</span><span id="mq-pct">0%</span></div>
    <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="mq-progress-fill" style="width:0%"></div></div>
    <div id="mq-question-area"></div>
    <div class="quiz-nav">
      <button class="btn" id="mq-next-btn" onclick="mqNext()" style="display:none">Question suivante →</button>
    </div>
  </div>

  <div class="score-screen" id="mq-score-screen">
    <div class="score-big" id="mq-final-score">0/100</div>
    <div class="score-label">Score final du Méga Quiz 🎉</div>
    <div class="score-mention" id="mq-mention"></div>
    <div class="score-details" id="mq-score-details"></div>
    <button class="btn" onclick="restartMegaQuiz()" style="margin-top:1rem">🔄 Recommencer</button>
    <button class="btn-outline" onclick="show('home',document.querySelector('[onclick*=home]'))" style="margin-top:1rem">🏠 Retour accueil</button>
  </div>
</div>

</div><!-- end main -->

<script>
// ============ NAV ============
function show(id,el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(el)el.classList.add('active');
  window.scrollTo(0,0);
}

// ============ VOCAB DATA ============
const allVocab=[
  {en:'Payslip',fr:'Bulletin de paie',cat:'work'},{en:'Salary',fr:'Salaire',cat:'work'},{en:'Employee',fr:'Salarié(e)',cat:'work'},{en:'Employer',fr:'Employeur',cat:'work'},{en:'Contract',fr:'Contrat',cat:'work'},{en:'Invoice',fr:'Facture',cat:'work'},{en:'Payment',fr:'Paiement',cat:'work'},{en:'Late payment',fr:'Retard de paiement',cat:'work'},{en:'Net salary',fr:'Salaire net',cat:'work'},{en:'Gross salary',fr:'Salaire brut',cat:'work'},{en:'Meeting',fr:'Réunion',cat:'work'},{en:'Deadline',fr:'Date limite',cat:'work'},{en:'Manager',fr:'Responsable',cat:'work'},{en:'Colleague',fr:'Collègue',cat:'work'},{en:'Office',fr:'Bureau',cat:'work'},
  {en:'Kitchen',fr:'Cuisine',cat:'home'},{en:'Living room',fr:'Salon',cat:'home'},{en:'Bedroom',fr:'Chambre',cat:'home'},{en:'Bathroom',fr:'Salle de bain',cat:'home'},{en:'Garden',fr:'Jardin',cat:'home'},{en:'Door',fr:'Porte',cat:'home'},{en:'Window',fr:'Fenêtre',cat:'home'},{en:'Stairs',fr:'Escaliers',cat:'home'},{en:'Washing machine',fr:'Machine à laver',cat:'home'},{en:'Fridge',fr:'Réfrigérateur',cat:'home'},{en:'Oven',fr:'Four',cat:'home'},{en:'Sofa',fr:'Canapé',cat:'home'},{en:'Wardrobe',fr:'Armoire',cat:'home'},{en:'Shelf',fr:'Étagère',cat:'home'},
  {en:'Wake up',fr:'Se réveiller',cat:'daily'},{en:'Get dressed',fr:"S'habiller",cat:'daily'},{en:'Have breakfast',fr:'Prendre le petit-déj',cat:'daily'},{en:'Go to work',fr:'Aller au travail',cat:'daily'},{en:'Have lunch',fr:'Déjeuner',cat:'daily'},{en:'Go shopping',fr:'Faire des courses',cat:'daily'},{en:'Cook dinner',fr:'Préparer le dîner',cat:'daily'},{en:'Pick up the kids',fr:'Aller chercher les enfants',cat:'daily'},{en:'Watch TV',fr:'Regarder la télé',cat:'daily'},{en:'Go to bed',fr:'Aller au lit',cat:'daily'},{en:'Take a shower',fr:'Prendre une douche',cat:'daily'},{en:'Do the laundry',fr:'Faire la lessive',cat:'daily'},
  {en:'Park',fr:'Parc',cat:'outside'},{en:'Supermarket',fr:'Supermarché',cat:'outside'},{en:'Pharmacy',fr:'Pharmacie',cat:'outside'},{en:'School',fr:'École',cat:'outside'},{en:'Hospital',fr:'Hôpital',cat:'outside'},{en:'Bank',fr:'Banque',cat:'outside'},{en:'Post office',fr:'Bureau de poste',cat:'outside'},{en:'Train station',fr:'Gare',cat:'outside'},{en:'Airport',fr:'Aéroport',cat:'outside'},{en:'Restaurant',fr:'Restaurant',cat:'outside'},{en:'Traffic jam',fr:'Embouteillage',cat:'outside'},{en:'Bus stop',fr:"Arrêt de bus",cat:'outside'},
  {en:'Apple',fr:'Pomme',cat:'food'},{en:'Bread',fr:'Pain',cat:'food'},{en:'Cheese',fr:'Fromage',cat:'food'},{en:'Chicken',fr:'Poulet',cat:'food'},{en:'Rice',fr:'Riz',cat:'food'},{en:'Vegetables',fr:'Légumes',cat:'food'},{en:'Coffee',fr:'Café',cat:'food'},{en:'Water',fr:'Eau',cat:'food'},{en:'Juice',fr:'Jus',cat:'food'},{en:'Cake',fr:'Gâteau',cat:'food'},
  {en:'Exhausted',fr:'Épuisé(e)',cat:'emotions'},{en:'Anxious',fr:'Anxieux/se',cat:'emotions'},{en:'Confident',fr:'Confiant(e)',cat:'emotions'},{en:'Frustrated',fr:'Frustré(e)',cat:'emotions'},{en:'Relieved',fr:'Soulagé(e)',cat:'emotions'},{en:'Overwhelmed',fr:'Débordé(e)',cat:'emotions'},{en:'Proud',fr:'Fier/fière',cat:'emotions'},{en:'Excited',fr:'Enthousiaste',cat:'emotions'},{en:'Worried',fr:'Inquiet/ète',cat:'emotions'},{en:'Grateful',fr:'Reconnaissant(e)',cat:'emotions'},
  {en:'To manage',fr:'Gérer',cat:'verbs'},{en:'To handle',fr:'Traiter',cat:'verbs'},{en:'To submit',fr:'Soumettre',cat:'verbs'},{en:'To achieve',fr:'Accomplir',cat:'verbs'},{en:'To improve',fr:'Améliorer',cat:'verbs'},{en:'To negotiate',fr:'Négocier',cat:'verbs'},{en:'To explain',fr:'Expliquer',cat:'verbs'},{en:'To understand',fr:'Comprendre',cat:'verbs'},{en:'To remember',fr:'Se souvenir',cat:'verbs'},{en:'To forget',fr:'Oublier',cat:'verbs'},
  {en:'As soon as possible',fr:'Dès que possible',cat:'expressions'},{en:'On time',fr:"À l'heure",cat:'expressions'},{en:'By the way',fr:'Au fait',cat:'expressions'},{en:'Nevertheless',fr:'Néanmoins',cat:'expressions'},{en:'Therefore',fr:'Donc',cat:'expressions'},{en:'However',fr:'Cependant',cat:'expressions'},{en:'For example',fr:'Par exemple',cat:'expressions'},{en:'In fact',fr:'En fait',cat:'expressions'},
];
const catLabels={work:'💼 Travail',home:'🏠 Maison',daily:'☀️ Quotidien',outside:'🌳 Extérieur',food:'🍽️ Nourriture',emotions:'😊 Émotions',verbs:'🔧 Verbe',expressions:'💬 Expression'};
function buildVocab(f='all'){const c=document.getElementById('vocab-container');c.innerHTML='';(f==='all'?allVocab:allVocab.filter(v=>v.cat===f)).forEach(item=>{const d=document.createElement('div');d.className='vocab-card';d.innerHTML=`<div class="vocab-cat">${catLabels[item.cat]}</div><div class="vocab-en">${item.en}</div><div class="vocab-fr">${item.fr}</div>`;c.appendChild(d);});}
function filterVocab(cat,btn){document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');buildVocab(cat);}

// ============ FLASHCARDS ============
const flashcards=allVocab.map(v=>({front:v.en,back:v.fr}));
let fcIndex=0;
function updateFC(){const c=flashcards[fcIndex];document.getElementById('fc-front').textContent=c.front;document.getElementById('fc-back').textContent=c.back;document.getElementById('fc-counter').textContent=(fcIndex+1)+' / '+flashcards.length;document.getElementById('flashcard').classList.remove('flipped');}
function flipCard(){document.getElementById('flashcard').classList.toggle('flipped');}
function nextCard(){fcIndex=(fcIndex+1)%flashcards.length;updateFC();}
function prevCard(){fcIndex=(fcIndex-1+flashcards.length)%flashcards.length;updateFC();}

// ============ QUIZ RAPIDE ============
const quizData=[
  {q:'She is ___ engineer.',o:['a','an','has','is'],c:1,e:'Engineer commence par E → AN'},{q:'My brother ___ a new phone.',o:['have','has','is','are'],c:1,e:'My brother = HE → HAS'},{q:'___ you like chocolate?',o:['Do','Does','Did','Are'],c:0,e:'You → DO'},{q:'They ___ at school yesterday.',o:['was','were','is','are'],c:1,e:'They → WERE 👻'},{q:'She ___ speak Italian.',o:["don't","doesn't","isn't","aren't"],c:1,e:"She → DOESN'T"},{q:'___ your boss angry yesterday?',o:['Were','Was','Did','Does'],c:1,e:'Your boss = HE → WAS 🔪'},{q:'I am ___ honest student.',o:['a','an','the','has'],c:1,e:'Honest = H muet → AN'},{q:'She is ___ (make) a cake.',o:['making','makeing','makes','made'],c:0,e:'make → enlève E → making'},{q:'___ they speak French?',o:['Do','Does','Did','Was'],c:0,e:'They → DO'},{q:'We ___ ready yesterday.',o:["wasn't","weren't","didn't","doesn't"],c:1,e:"We → WEREN'T 👻"},{q:'I ___ visited Paris before.',o:['have','has','did','was'],c:0,e:'Present Perfect : I → HAVE'},{q:'She ___ going to call you.',o:['am','is','are','be'],c:1,e:'She → IS going to'},{q:'Will she ___ tomorrow?',o:['works','working','work','worked'],c:2,e:'Après WILL → verbe normal sans S'},{q:'She is tall___ than me.',o:['er','est','more','most'],c:0,e:'Adjectif court → + ER'},{q:'This is ___ car.',o:['her','hers','she','him'],c:0,e:'Devant un nom → HER (possessif adj.)'},{q:'___ you ever been to London?',o:['Did','Have','Was','Do'],c:1,e:'Present Perfect question → HAVE'},{q:'The meeting is ___ Monday.',o:['in','on','at','to'],c:1,e:'Jour de la semaine → ON'},{q:'She has ___ finished work.',o:['just','ever','yet','still'],c:0,e:'JUST = venir de faire'},{q:'It is ___ best restaurant.',o:['a','an','the','—'],c:2,e:'Superlatif → THE best'},{q:'___ she working right now?',o:['Do','Does','Is','Has'],c:2,e:'Action en cours → IS she working?'},
];
let qScore=0,qAnswered=[];
function buildQuiz(){const c=document.getElementById('quiz-container');c.innerHTML='';quizData.forEach((q,i)=>{const d=document.createElement('div');d.className='quiz-question-card';d.id='qq'+i;d.innerHTML=`<div class="quiz-q-num">Question ${i+1}/20</div><div class="quiz-q-text"><em>"${q.q}"</em></div><div class="quiz-opts">${q.o.map((o,j)=>`<button class="quiz-opt" onclick="answerQ(${i},${j})">${o}</button>`).join('')}</div><div class="quiz-feedback-card" id="qf${i}"></div>`;c.appendChild(d);});}
function answerQ(qi,ai){if(qAnswered.includes(qi))return;qAnswered.push(qi);const q=quizData[qi];document.querySelectorAll('#qq'+qi+' .quiz-opt').forEach((b,i)=>{if(i===q.c)b.classList.add('correct');else if(i===ai)b.classList.add('wrong');b.disabled=true;});const fb=document.getElementById('qf'+qi);if(ai===q.c){qScore++;fb.textContent='✅ '+q.e;fb.className='quiz-feedback-card show correct';}else{fb.textContent='❌ Réponse : '+q.o[q.c]+' — '+q.e;fb.className='quiz-feedback-card show wrong';}if(qAnswered.length===quizData.length){document.getElementById('score-num').textContent=qScore+'/20';document.getElementById('quiz-score').classList.add('show');}}
function restartQuiz(){qScore=0;qAnswered=[];document.getElementById('quiz-score').classList.remove('show');buildQuiz();}

// ============ EXERCISES ============
const exercises=[
  {s:'My colleague ___ late this morning.',a:'was',h:'was/were'},{s:'Your friends ___ at the party.',a:'were',h:'was/were'},{s:'She ___ speak Italian.',a:"doesn't",h:"don't/doesn't"},{s:'___ you like music?',a:'Do',h:'Do/Does'},{s:'I am ___ honest person.',a:'an',h:'a/an'},{s:'He ___ a new car.',a:'has',h:'has/have'},{s:'They ___ (run) in the park right now.',a:'are running',h:'am/is/are + -ing'},{s:'___ she work on Sundays?',a:'Does',h:'Do/Does'},{s:'I have ___ seen that film.',a:'never',h:'ever/never/just'},{s:'She ___ going to call you tomorrow.',a:'is',h:'am/is/are'},{s:'The meeting is ___ Monday.',a:'on',h:'in/on/at'},{s:'Will you ___ me?',a:'forgive',h:'verbe normal'},
];
let chronoInt,chronoSec=0;
function startChrono(){clearInterval(chronoInt);chronoSec=0;chronoInt=setInterval(()=>{chronoSec++;const m=Math.floor(chronoSec/60),s=chronoSec%60;document.getElementById('chrono').textContent=m+':'+(s<10?'0':'')+s;},1000);}
function buildExercises(){const c=document.getElementById('exercise-container');c.innerHTML='';exercises.forEach((ex,i)=>{const d=document.createElement('div');d.className='quiz-question-card';const p=ex.s.split('___');d.innerHTML=`<div class="ex-sentence">${i+1}. ${p[0]}<input class="exercise-input" id="ex${i}" placeholder="${ex.h}">${p[1]||''}</div>`;c.appendChild(d);});startChrono();}
function checkExercises(){clearInterval(chronoInt);let s=0;exercises.forEach((ex,i)=>{const inp=document.getElementById('ex'+i);if(inp.value.trim().toLowerCase()===ex.a.toLowerCase()){s++;inp.classList.add('correct');inp.classList.remove('wrong');}else{inp.classList.add('wrong');inp.classList.remove('correct');}});document.getElementById('exercise-result').innerHTML=`<div class="lesson-card"><div class="lesson-title">${s===exercises.length?'🎉 Parfait !':'💪 Score'}</div><div style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--sage-dark)">${s}/${exercises.length}</div><div style="font-size:0.82rem;color:var(--text-light)">Temps : ${document.getElementById('chrono').textContent}</div></div>`;}
function resetExercises(){exercises.forEach((_,i)=>{const inp=document.getElementById('ex'+i);if(inp){inp.value='';inp.className='exercise-input';}});document.getElementById('exercise-result').innerHTML='';startChrono();}

// ============ BUILD SENTENCES ============
const buildData=[
  {affirm:'She works every day.',neg:"She doesn't work every day.",interro:'Does she work every day?'},
  {affirm:'He has a new car.',neg:"He doesn't have a new car.",interro:'Does he have a new car?'},
  {affirm:'They were happy.',neg:"They weren't happy.",interro:'Were they happy?'},
  {affirm:'I am going to call you.',neg:"I am not going to call you.",interro:'Are you going to call me?'},
];
function buildBuildSentences(){const c=document.getElementById('build-container');if(!c)return;c.innerHTML='';buildData.forEach((item,i)=>{const d=document.createElement('div');d.className='quiz-question-card';d.innerHTML=`<div class="quiz-q-text">📝 <strong>AFFIRMATIF :</strong> ${item.affirm}</div><div style="margin-bottom:0.4rem;font-size:0.82rem;color:var(--text-light)">❌ NÉGATIF :</div><input class="exercise-input" id="neg${i}" placeholder="Écris la phrase négative..." style="width:100%;margin-bottom:0.6rem"><div style="margin-bottom:0.4rem;font-size:0.82rem;color:var(--text-light)">❓ QUESTION :</div><input class="exercise-input" id="int${i}" placeholder="Écris la question..." style="width:100%">`;c.appendChild(d);});}
function checkBuild(){let s=0,t=buildData.length*2;buildData.forEach((item,i)=>{const neg=document.getElementById('neg'+i),int=document.getElementById('int'+i);if(neg&&neg.value.trim().toLowerCase()===item.neg.toLowerCase()){s++;neg.classList.add('correct');neg.classList.remove('wrong');}else if(neg){neg.classList.add('wrong');neg.classList.remove('correct');neg.placeholder=item.neg;}if(int&&int.value.trim().toLowerCase()===item.interro.toLowerCase()){s++;int.classList.add('correct');int.classList.remove('wrong');}else if(int){int.classList.add('wrong');int.classList.remove('correct');int.placeholder=item.interro;}});document.getElementById('build-result').innerHTML=`<div class="lesson-card"><div class="lesson-title">${s===t?'🎉 Parfait !':'💪 Score'}</div><div style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:var(--sage-dark)">${s}/${t}</div></div>`;}
function resetBuild(){buildData.forEach((_,i)=>{['neg','int'].forEach(p=>{const el=document.getElementById(p+i);if(el){el.value='';el.className='exercise-input';}});});document.getElementById('build-result').innerHTML='';}

