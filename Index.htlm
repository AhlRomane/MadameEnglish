  {cat:'vocab',catLabel:'📚 Vocabulaire',q:'"Traffic jam" en français ?',o:['Arrêt de bus','Embouteillage','Aéroport','Gare'],c:1,e:'Traffic jam = Embouteillage'},
  {cat:'vocab',catLabel:'📚 Vocabulaire',q:'"Relieved" en français ?',o:['Soulagé','Épuisé','Frustré','Confiant'],c:0,e:'Relieved = Soulagé(e)'},
  {cat:'vocab',catLabel:'📚 Vocabulaire',q:'"Gross salary" en français ?',o:['Salaire net','Salaire brut','Bulletin de paie','Contrat'],c:1,e:'Gross salary = Salaire brut'},
  {cat:'vocab',catLabel:'📚 Vocabulaire',q:'"To improve" en français ?',o:['Gérer','Soumettre','Améliorer','Accomplir'],c:2,e:'To improve = Améliorer'},
  {cat:'vocab',catLabel:'📚 Vocabulaire',q:'"Pick up the kids" en français ?',o:['Faire la lessive','Préparer le dîner','Aller chercher les enfants','Se réveiller'],c:2,e:'Pick up the kids = Aller chercher les enfants'},

  // PLURIELS IRRÉGULIERS (5)
  {cat:'vocab',catLabel:'🔤 Pluriels',q:'Pluriel de "child" ?',o:['childs','childen','children','childrens'],c:2,e:'Child → Children (pluriel irrégulier !)'},
  {cat:'vocab',catLabel:'🔤 Pluriels',q:'Pluriel de "woman" ?',o:['womans','womens','women','womas'],c:2,e:'Woman → Women (A devient E)'},
  {cat:'vocab',catLabel:'🔤 Pluriels',q:'Pluriel de "tooth" ?',o:['tooths','teeths','tothes','teeth'],c:3,e:'Tooth → Teeth (OO devient EE)'},
  {cat:'vocab',catLabel:'🔤 Pluriels',q:'Pluriel de "sheep" ?',o:['sheeps','sheepies','sheep','sheepes'],c:2,e:'Sheep → Sheep (ne change pas !)'},
  {cat:'vocab',catLabel:'🔤 Pluriels',q:'Pluriel de "mouse" ?',o:['mouses','mouse','meese','mice'],c:3,e:'Mouse → Mice'},

  // PHRASES A/N/I (5)
  {cat:'phrases',catLabel:'📝 Phrases A/N/I',q:'Transforme en NÉGATIF : "She works every day."',o:["She doesn't works every day.","She doesn't work every day.","She not work every day.","She isn't work every day."],c:1,e:"DOESN'T + verbe sans S"},
  {cat:'phrases',catLabel:'📝 Phrases A/N/I',q:'Transforme en QUESTION : "He has a car."',o:['Does he has a car?','Do he have a car?','Does he have a car?','Has he a car?'],c:2,e:'DOES + sujet + verbe sans S'},
  {cat:'phrases',catLabel:'📝 Phrases A/N/I',q:'Transforme en NÉGATIF : "They were happy."',o:["They wasn't happy.","They weren't happy.","They didn't happy.","They not were happy."],c:1,e:"They → WEREN'T"},
  {cat:'phrases',catLabel:'📝 Phrases A/N/I',q:'Transforme en QUESTION : "She will call."',o:['Does she will call?','Do she will call?','Will she calls?','Will she call?'],c:3,e:'WILL + sujet + verbe normal'},
  {cat:'phrases',catLabel:'📝 Phrases A/N/I',q:'Quelle phrase est correcte ?',o:['Does she speaks French?','Does she speak French?','Do she speaks French?','Do she speak French?'],c:1,e:'DOES + she + speak (sans S !)'},
];

// MEGA QUIZ STATE
let mqIndex=0, mqScore=0, mqAnswered=false;
const mqCatScores={grammar:0,conjugaison:0,pronoms:0,vocab:0,phrases:0};
const mqCatTotal={grammar:0,conjugaison:0,pronoms:0,vocab:0,phrases:0};
megaQuizData.forEach(q=>mqCatTotal[q.cat]++);

function startMegaQuiz(){
  mqIndex=0;mqScore=0;mqAnswered=false;
  Object.keys(mqCatScores).forEach(k=>mqCatScores[k]=0);
  document.getElementById('mq-intro').style.display='none';
  document.getElementById('mq-content').style.display='block';
  document.getElementById('mq-score-screen').classList.remove('show');
  renderMQQuestion();
}

function renderMQQuestion(){
  mqAnswered=false;
  const q=megaQuizData[mqIndex];
  const pct=Math.round((mqIndex/megaQuizData.length)*100);
  document.getElementById('mq-progress-fill').style.width=pct+'%';
  document.getElementById('mq-progress-text').textContent='Question '+(mqIndex+1)+'/100';
  document.getElementById('mq-pct').textContent=pct+'%';
  document.getElementById('mq-live-score').textContent=mqScore;
  document.getElementById('mq-next-btn').style.display='none';

  const catColors={grammar:'cat-grammar',conjugaison:'cat-conjugaison',pronoms:'cat-pronoms',vocab:'cat-vocab',phrases:'cat-phrases'};
  const area=document.getElementById('mq-question-area');
  area.innerHTML=`
    <div class="quiz-question-card">
      <div class="quiz-q-num">Question ${mqIndex+1}/100</div>
      <div style="margin-bottom:0.5rem"><span class="quiz-category-badge ${catColors[q.cat]}">${q.catLabel}</span></div>
      <div class="quiz-q-text">${q.q}</div>
      <div class="quiz-opts">${q.o.map((o,j)=>`<button class="quiz-opt" id="mqopt${j}" onclick="answerMQ(${j})">${o}</button>`).join('')}</div>
      <div class="quiz-feedback-card" id="mq-fb"></div>
    </div>`;
}

function answerMQ(ai){
  if(mqAnswered)return;
  mqAnswered=true;
  const q=megaQuizData[mqIndex];
  q.o.forEach((_,i)=>{
    const btn=document.getElementById('mqopt'+i);
    if(i===q.c)btn.classList.add('correct');
    else if(i===ai)btn.classList.add('wrong');
    btn.disabled=true;
  });
  const fb=document.getElementById('mq-fb');
  if(ai===q.c){mqScore++;mqCatScores[q.cat]++;fb.textContent='✅ '+q.e;fb.className='quiz-feedback-card show correct';}
  else{fb.textContent='❌ Réponse correcte : '+q.o[q.c]+' — '+q.e;fb.className='quiz-feedback-card show wrong';}
  document.getElementById('mq-live-score').textContent=mqScore;

  if(mqIndex<megaQuizData.length-1){document.getElementById('mq-next-btn').style.display='inline-block';}
  else{setTimeout(showMQScore,800);}
}

function mqNext(){
  mqIndex++;
  if(mqIndex<megaQuizData.length){renderMQQuestion();window.scrollTo(0,document.getElementById('mq-content').offsetTop-20);}
  else{showMQScore();}
}

function showMQScore(){
  document.getElementById('mq-content').style.display='none';
  const screen=document.getElementById('mq-score-screen');
  screen.classList.add('show');
  document.getElementById('mq-final-score').textContent=mqScore+'/100';
  const pct=mqScore;
  let mention,color;
  if(pct>=90){mention='🏆 Excellent ! Tu maîtrises parfaitement !';color='background:#e8f5ec;color:#2d7a4f';}
  else if(pct>=75){mention='⭐ Très bien ! Continue comme ça !';color='background:#faf3e0;color:'+getComputedStyle(document.documentElement).getPropertyValue('--gold');}
  else if(pct>=60){mention='💪 Bien ! Quelques points à revoir.';color='background:var(--sage-pale);color:var(--sage-dark)';}
  else{mention='📚 Continue à réviser, tu vas progresser !';color='background:#faeae8;color:var(--red)';}
  const m=document.getElementById('mq-mention');m.textContent=mention;m.style.cssText=color+';border-radius:50px;padding:0.5rem 1.5rem;font-size:0.95rem;';
  const catNames={grammar:'📌 Grammaire',conjugaison:'⏮️ Conjugaison',pronoms:'👤 Pronoms & Adj.',vocab:'📚 Vocabulaire & Prep.',phrases:'📝 Phrases'};
  document.getElementById('mq-score-details').innerHTML=Object.keys(mqCatScores).map(k=>`<div class="score-detail-card"><div class="score-detail-cat">${catNames[k]}</div><div class="score-detail-num">${mqCatScores[k]}/${mqCatTotal[k]}</div><div class="score-detail-label">${Math.round((mqCatScores[k]/mqCatTotal[k])*100)}% réussi</div></div>`).join('');
}

function restartMegaQuiz(){
  document.getElementById('mq-score-screen').classList.remove('show');
  startMegaQuiz();
}

// INIT
buildVocab();buildQuiz();buildExercises();buildBuildSentences();
</script>
</body>
</html>
