    <div class="card" onclick="show('mega-quiz',document.querySelector('[onclick*=mega-quiz]'))"><div class="card-icon">🏆</div><div class="card-title">Méga Quiz 100 questions</div><div class="card-sub">Le grand défi !</div></div>
    <div class="card" onclick="show('types',document.querySelector('[onclick*=types]'))"><div class="card-icon">📝</div><div class="card-title">Phrases A/N/I</div><div class="card-sub">La base absolue</div></div>
    <div class="card" onclick="show('music',document.querySelector('[onclick*=music]'))"><div class="card-icon">🎵</div><div class="card-title">Musique</div><div class="card-sub">Bruno Mars, Muse...</div></div>
    <div class="card" onclick="show('vocab',document.querySelector('[onclick*=vocab]'))"><div class="card-icon">📚</div><div class="card-title">Vocabulaire</div><div class="card-sub">Par thème</div></div>
    <div class="card" onclick="show('quiz',document.querySelector('[onclick*=quiz]'))"><div class="card-icon">🎯</div><div class="card-title">Quiz rapide</div><div class="card-sub">20 questions</div></div>
    <div class="card" onclick="show('build-sentences',document.querySelector('[onclick*=build]'))"><div class="card-icon">🔨</div><div class="card-title">Construire des phrases</div><div class="card-sub">Affirm. Nég. Interro.</div></div>
    <div class="card" onclick="show('present-perfect',document.querySelector('[onclick*=present-perfect]'))"><div class="card-icon">⭐</div><div class="card-title">Present Perfect</div><div class="card-sub">Have you ever...?</div></div>
    <div class="card" onclick="show('flashcards',document.querySelector('[onclick*=flashcards]'))"><div class="card-icon">🃏</div><div class="card-title">Flashcards</div><div class="card-sub">Mémorise !</div></div>
  </div>
</div>

<!-- TYPES -->
<div id="types" class="section">
  <div class="page-title">Phrases Affirmative • Négative • Interrogative</div>
  <div class="page-sub">La base absolue — tout part de là !</div>
  <div class="lesson-card">
    <div class="lesson-title">📖 Les 3 types</div>
    <div class="three-types">
      <div class="type-card affirm"><div class="type-label">✅ AFFIRMATIVE</div><div class="type-formula">Sujet + Verbe + Complément</div><div class="type-example">She works every day.<br><small>Elle travaille tous les jours.</small></div></div>
      <div class="type-card neg"><div class="type-label">❌ NÉGATIVE</div><div class="type-formula">Sujet + Don't/Doesn't + Verbe</div><div class="type-example">She doesn't work.<br><small>Elle ne travaille pas.</small></div></div>
      <div class="type-card interro"><div class="type-label">❓ INTERROGATIVE</div><div class="type-formula">Do/Does + Sujet + Verbe ?</div><div class="type-example">Does she work?<br><small>Est-ce qu'elle travaille ?</small></div></div>
    </div>
  </div>
  <div class="lesson-card">
    <div class="lesson-title">💡 Le tableau magique COMPLET</div>
    <table class="rule-table">
      <tr><th>Temps</th><th>✅ Affirmatif</th><th>❌ Négatif</th><th>❓ Question</th></tr>
      <tr><td>Présent</td><td>She work<strong>s</strong>.</td><td>She <strong>doesn't</strong> work.</td><td><strong>Does</strong> she work?</td></tr>
      <tr><td>Présent continu</td><td>She <strong>is</strong> work<strong>ing</strong>.</td><td>She <strong>isn't</strong> working.</td><td><strong>Is</strong> she working?</td></tr>
      <tr><td>Passé</td><td>She work<strong>ed</strong>.</td><td>She <strong>didn't</strong> work.</td><td><strong>Did</strong> she work?</td></tr>
      <tr><td>Passé être</td><td>She <strong>was</strong> tired.</td><td>She <strong>wasn't</strong> tired.</td><td><strong>Was</strong> she tired?</td></tr>
      <tr><td>Futur WILL</td><td>She <strong>will</strong> work.</td><td>She <strong>won't</strong> work.</td><td><strong>Will</strong> she work?</td></tr>
      <tr><td>Futur GOING TO</td><td>She <strong>is going to</strong> work.</td><td>She <strong>isn't going to</strong> work.</td><td><strong>Is</strong> she going to work?</td></tr>
      <tr><td>Present Perfect</td><td>She <strong>has</strong> work<strong>ed</strong>.</td><td>She <strong>hasn't</strong> worked.</td><td><strong>Has</strong> she worked?</td></tr>
    </table>
  </div>
</div>

<!-- A/AN -->
<div id="a-an" class="section">
  <div class="page-title">A / AN</div><div class="page-sub">Les articles indéfinis</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Article</th><th>Quand ?</th><th>Exemples</th></tr>
      <tr><td><span class="tag tag-sage">A</span></td><td>Devant une consonne</td><td>a car, a dog, a new phone, a house</td></tr>
      <tr><td><span class="tag tag-brown">AN</span></td><td>Devant une voyelle (a,e,i,o,u) ou H muet</td><td>an apple, an umbrella, an honest man, an hour</td></tr>
    </table>
    <div class="warn-box">⚠️ H muet → an honest, an hour | Astuce : prononce le mot, si tu entends une voyelle → AN</div>
  </div>
  <div class="lesson-card"><div class="lesson-title">✍️ Exemples</div>
    <div class="example"><div class="en">She is <strong>an</strong> engineer.</div><div class="fr">Elle est ingénieure.</div></div>
    <div class="example"><div class="en">I have <strong>a</strong> new car.</div><div class="fr">J'ai une nouvelle voiture.</div></div>
    <div class="example"><div class="en">He is <strong>an</strong> honest man.</div><div class="fr">C'est un homme honnête.</div></div>
  </div>
</div>

<!-- HAS/HAVE -->
<div id="has-have" class="section">
  <div class="page-title">HAS / HAVE</div><div class="page-sub">Avoir et posséder</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Verbe</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I, you, we, they</td><td><span class="tag tag-sage">HAVE</span></td><td>I have a car</td><td>J'ai une voiture</td></tr>
      <tr><td>He, she, it</td><td><span class="tag tag-brown">HAS</span></td><td>She has a dog</td><td>Elle a un chien</td></tr>
    </table>
    <div class="tip-box">💡 Remplace par HE/SHE/IT → HAS | Tout le reste → HAVE<br>HAS = possession | IS HAVING = action en cours</div>
  </div>
</div>

<!-- AM/IS/ARE -->
<div id="am-is-are" class="section">
  <div class="page-title">AM / IS / ARE</div><div class="page-sub">Le verbe être au présent</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Verbe</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I</td><td><span class="tag tag-red">AM</span></td><td>I am a student</td><td>Je suis étudiant(e)</td></tr>
      <tr><td>He, she, it</td><td><span class="tag tag-sage">IS</span></td><td>She is happy</td><td>Elle est heureuse</td></tr>
      <tr><td>You, we, they</td><td><span class="tag tag-brown">ARE</span></td><td>They are tired</td><td>Ils sont fatigués</td></tr>
    </table>
  </div>
</div>

<!-- ING -->
<div id="ing" class="section">
  <div class="page-title">AM/IS/ARE + -ING</div><div class="page-sub">Action en cours</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Formation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I</td><td>AM + verbe-ing</td><td>I am eating</td><td>Je suis en train de manger</td></tr>
      <tr><td>He, she, it</td><td>IS + verbe-ing</td><td>She is running</td><td>Elle court en ce moment</td></tr>
      <tr><td>You, we, they</td><td>ARE + verbe-ing</td><td>They are watching</td><td>Ils regardent en ce moment</td></tr>
    </table>
    <div class="warn-box">⚠️ E muet → enlève le E : make→making | write→writing | have→having</div>
  </div>
</div>

<!-- DO/DOES -->
<div id="do-does" class="section">
  <div class="page-title">DO / DOES</div><div class="page-sub">Questions au présent</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Question</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I, you, we, they</td><td><span class="tag tag-sage">DO</span></td><td>Do you like pizza?</td><td>Tu aimes la pizza ?</td></tr>
      <tr><td>He, she, it</td><td><span class="tag tag-brown">DOES</span></td><td>Does she speak English?</td><td>Elle parle anglais ?</td></tr>
    </table>
    <div class="warn-box">⚠️ Jamais de S sur le verbe avec DO/DOES !</div>
  </div>
</div>

<!-- DON'T/DOESN'T -->
<div id="dont-doesnt" class="section">
  <div class="page-title">DON'T / DOESN'T</div><div class="page-sub">Négation au présent</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Négation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I, you, we, they</td><td><span class="tag tag-sage">DON'T</span></td><td>I don't like coffee</td><td>Je n'aime pas le café</td></tr>
      <tr><td>He, she, it</td><td><span class="tag tag-brown">DOESN'T</span></td><td>She doesn't speak Spanish</td><td>Elle ne parle pas espagnol</td></tr>
    </table>
  </div>
</div>

<!-- WAS/WERE -->
<div id="was-were" class="section">
  <div class="page-title">WAS / WERE</div><div class="page-sub">Le verbe être au passé 🎬</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Affirmatif</th><th>Négatif</th><th>Question</th></tr>
      <tr><td>I, he, she, it</td><td><span class="tag tag-brown">WAS</span></td><td><span class="tag tag-red">WASN'T</span></td><td>Was she happy?</td></tr>
      <tr><td>You, we, they</td><td><span class="tag tag-sage">WERE</span></td><td><span class="tag tag-red">WEREN'T</span></td><td>Were they tired?</td></tr>
    </table>
    <div class="film-box"><div class="film-emoji">🔪</div><div><div class="film-title">SAW → WAS / WASN'T</div><div class="film-rule">I / He / She / It</div></div></div>
    <div class="film-box"><div class="film-emoji">👻</div><div><div class="film-title">Les WARREN → WERE / WEREN'T</div><div class="film-rule">You / We / They</div></div></div>
  </div>
</div>

<!-- DID/DIDN'T -->
<div id="did-didnt" class="section">
  <div class="page-title">DID / DIDN'T</div><div class="page-sub">Actions au passé</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Type</th><th>Formation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>✅ Affirmatif</td><td>Sujet + verbe passé</td><td>She worked / She ate</td><td>Elle a travaillé / mangé</td></tr>
      <tr><td>❌ Négatif</td><td>Sujet + DIDN'T + verbe normal</td><td>She didn't work</td><td>Elle n'a pas travaillé</td></tr>
      <tr><td>❓ Question</td><td>DID + sujet + verbe normal</td><td>Did she work?</td><td>A-t-elle travaillé ?</td></tr>
    </table>
    <div class="tip-box">💡 DID/DIDN'T = même pour tout le monde !</div>
  </div>
  <div class="lesson-card"><div class="lesson-title">📚 Verbes irréguliers</div>
    <div class="two-col">
      <table class="rule-table">
        <tr><th>Présent</th><th>Passé</th><th>Traduction</th></tr>
        <tr><td>eat</td><td><strong>ate</strong></td><td>manger → a mangé</td></tr>
        <tr><td>go</td><td><strong>went</strong></td><td>aller → est allé</td></tr>
        <tr><td>have</td><td><strong>had</strong></td><td>avoir → a eu</td></tr>
        <tr><td>write</td><td><strong>wrote</strong></td><td>écrire → a écrit</td></tr>
        <tr><td>run</td><td><strong>ran</strong></td><td>courir → a couru</td></tr>
      </table>
      <table class="rule-table">
        <tr><th>Présent</th><th>Passé</th><th>Traduction</th></tr>
        <tr><td>see</td><td><strong>saw</strong></td><td>voir → a vu</td></tr>
        <tr><td>speak</td><td><strong>spoke</strong></td><td>parler → a parlé</td></tr>
        <tr><td>drink</td><td><strong>drank</strong></td><td>boire → a bu</td></tr>
        <tr><td>come</td><td><strong>came</strong></td><td>venir → est venu</td></tr>
        <tr><td>take</td><td><strong>took</strong></td><td>prendre → a pris</td></tr>
      </table>
    </div>
  </div>
</div>

<!-- FUTURE -->
<div id="future" class="section">
  <div class="page-title">Le Futur 🔮</div><div class="page-sub">WILL et GOING TO</div>
  <div class="lesson-card"><div class="lesson-title">📖 WILL</div>
    <table class="rule-table">
      <tr><th>Type</th><th>Formation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>✅</td><td>Sujet + WILL + verbe</td><td>I will call you.</td><td>Je t'appellerai.</td></tr>
      <tr><td>❌</td><td>Sujet + WON'T + verbe</td><td>She won't come.</td><td>Elle ne viendra pas.</td></tr>
      <tr><td>❓</td><td>WILL + sujet + verbe</td><td>Will he work?</td><td>Travaillera-t-il ?</td></tr>
    </table>
  </div>
  <div class="lesson-card"><div class="lesson-title">📖 GOING TO</div>
    <table class="rule-table">
      <tr><th>Pronom</th><th>Formation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>I</td><td>I AM going to</td><td>I am going to work.</td><td>Je vais travailler.</td></tr>
      <tr><td>He/She/It</td><td>IS going to</td><td>She is going to eat.</td><td>Elle va manger.</td></tr>
      <tr><td>You/We/They</td><td>ARE going to</td><td>They are going to run.</td><td>Ils vont courir.</td></tr>
    </table>
  </div>
</div>

<!-- PRESENT PERFECT -->
<div id="present-perfect" class="section">
  <div class="page-title">Present Perfect ⭐</div><div class="page-sub">Have you ever...?</div>
  <div class="lesson-card"><div class="lesson-title">📖 La règle</div>
    <table class="rule-table">
      <tr><th>Type</th><th>Formation</th><th>Exemple</th><th>Traduction</th></tr>
      <tr><td>✅</td><td>Sujet + HAVE/HAS + participe passé</td><td>I have visited Paris.</td><td>J'ai visité Paris.</td></tr>
      <tr><td>❌</td><td>Sujet + HAVEN'T/HASN'T + verbe</td><td>She hasn't eaten yet.</td><td>Elle n'a pas encore mangé.</td></tr>
      <tr><td>❓</td><td>HAVE/HAS + sujet + verbe</td><td>Have you ever been to London?</td><td>Es-tu déjà allé(e) à Londres ?</td></tr>
    </table>
    <div class="tip-box">💡 Mots clés : ever (déjà) | never (jamais) | already (déjà) | yet (encore/déjà) | just (venir de)</div>
  </div>
</div>

<!-- PRONOUNS -->
<div id="pronouns" class="section">
  <div class="page-title">Les Pronoms 👤</div><div class="page-sub">Sujet, objet, possessif</div>
  <div class="lesson-card"><div class="lesson-title">📖 Tableau complet</div>
    <table class="rule-table">
      <tr><th>Personne</th><th>Sujet</th><th>Objet</th><th>Possessif adj.</th><th>Possessif pronom</th></tr>
      <tr><td>Je</td><td><strong>I</strong></td><td><strong>me</strong></td><td><strong>my</strong></td><td><strong>mine</strong></td></tr>
      <tr><td>Tu/Vous</td><td><strong>you</strong></td><td><strong>you</strong></td><td><strong>your</strong></td><td><strong>yours</strong></td></tr>
      <tr><td>Il</td><td><strong>he</strong></td><td><strong>him</strong></td><td><strong>his</strong></td><td><strong>his</strong></td></tr>
      <tr><td>Elle</td><td><strong>she</strong></td><td><strong>her</strong></td><td><strong>her</strong></td><td><strong>hers</strong></td></tr>
      <tr><td>Il/Elle (chose)</td><td><strong>it</strong></td><td><strong>it</strong></td><td><strong>its</strong></td><td>—</td></tr>
      <tr><td>Nous</td><td><strong>we</strong></td><td><strong>us</strong></td><td><strong>our</strong></td><td><strong>ours</strong></td></tr>
      <tr><td>Ils/Elles</td><td><strong>they</strong></td><td><strong>them</strong></td><td><strong>their</strong></td><td><strong>theirs</strong></td></tr>
    </table>
  </div>
</div>

<!-- ADJECTIVES -->
<div id="adjectives" class="section">
  <div class="page-title">Adjectifs 🎨</div><div class="page-sub">Décrire, comparer, superlatif</div>
  <div class="lesson-card"><div class="lesson-title">📖 Comparatifs & Superlatifs</div>
    <table class="rule-table">
      <tr><th>Adjectif</th><th>Comparatif</th><th>Superlatif</th></tr>
      <tr><td>big</td><td>bigger than</td><td>the biggest</td></tr>
      <tr><td>small</td><td>smaller than</td><td>the smallest</td></tr>
      <tr><td>beautiful</td><td>more beautiful than</td><td>the most beautiful</td></tr>
      <tr><td>good</td><td>better than</td><td>the best</td></tr>
      <tr><td>bad</td><td>worse than</td><td>the worst</td></tr>
    </table>
  </div>
</div>

<!-- PREPOSITIONS -->
<div id="prepositions" class="section">
  <div class="page-title">Prépositions 📍</div><div class="page-sub">IN, ON, AT...</div>
  <div class="lesson-card"><div class="lesson-title">📖 Temps et Lieu</div>
    <table class="rule-table">
      <tr><th>Préposition</th><th>Temps</th><th>Lieu</th></tr>
      <tr><td><span class="tag tag-sage">IN</span></td><td>in January, in 2026, in summer</td><td>in the box, in France</td></tr>
      <tr><td><span class="tag tag-brown">ON</span></td><td>on Monday, on 25th April</td><td>on the table, on the wall</td></tr>
      <tr><td><span class="tag tag-gold">AT</span></td><td>at 8pm, at noon, at night</td><td>at home, at school, at work</td></tr>
    </table>
  </div>
</div>

<!-- VOCAB -->
<div id="vocab" class="section">
  <div class="page-title">Vocabulaire par thème 📚</div><div class="page-sub">200+ mots organisés !</div>
  <div class="vocab-filters">
    <button class="filter-btn active" onclick="filterVocab('all',this)">Tout</button>
