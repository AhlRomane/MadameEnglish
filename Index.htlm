      <div class="hero-stat"><div class="hero-stat-num">100</div><div class="hero-stat-label">questions 🏆</div></div>
      <div class="hero-stat"><div class="hero-stat-num">200+</div><div class="hero-stat-label">mots 📚</div></div>
    </div>
  </div>
